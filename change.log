+def truncated_normal(mean, std, low, high, device):
+    from torch.distributions import Normal
+    """使用截断正态分布"""
+    dist = Normal(mean, std)
+    # 应用截断约束
+    sample = dist.sample().to(device)  # 使用重参数化采样
+    # 硬截断（可能会改变分布形状）
+    return torch.clamp(sample, low, high)
+
